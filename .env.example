# Environment variables for Matrimony backend
# Copy this file to .env and fill in production values as needed.

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Database mode: prod for PostgreSQL, anything else for SQLite
DATABASE_ENV=dev

# PostgreSQL settings used only when DATABASE_ENV=prod
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=
